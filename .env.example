# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it contains secrets.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=user_management

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long, random string for JWT_SECRET in production.
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_SECONDS=86400

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
